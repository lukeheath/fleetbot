# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# GitHub
GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO=fleetdm/fleet
GITHUB_BASE_BRANCH=main
GITOPS_BASE_PATH=it-and-security
GITHUB_BOT_USERNAME=your-bot-github-username

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret
PORT=3000

# CI auto-fix (set to false to disable)
GITOPS_CI_CHECK_NAME=fleet-gitops
CI_AUTO_FIX=true

# Fleet MCP Server
FLEET_MCP_URL=http://localhost:8080/sse
